---
import PrototypePreviewer from './PrototypePreviewer.astro';
import TransitionDemoStyles from './TransitionDemoStyles.astro';
import { getAvailableDemos } from './demo-modules';
import { AdapterIds, type RuntimeId } from './runtimes/registry';

type DemoGroup = {
  id: string;
  label: string;
  demos: string[];
};

const runtimeLabels: Record<RuntimeId, string> = {
  wc: 'Web Components',
  react: 'React',
  vue: 'Vue',
};

const groupLabels: Record<string, string> = {
  base: 'Base',
  shadcn: 'Shadcn',
  other: 'Other',
};

function formatDemoLabel(id: string) {
  return id
    .replace(/^demo-/, '')
    .replace(/-/g, ' ')
    .replace(/\b\w/g, (char) => char.toUpperCase());
}

function getGroupId(id: string) {
  if (id.includes('base')) return 'base';
  if (id.includes('shadcn') || id.includes('button')) return 'shadcn';
  return 'other';
}

const demos = getAvailableDemos().sort((a, b) => a.localeCompare(b));
const runtimes = AdapterIds as RuntimeId[];
const groups = demos.reduce<DemoGroup[]>((result, demoId) => {
  const groupId = getGroupId(demoId);
  let group = result.find((item) => item.id === groupId);
  if (!group) {
    group = { id: groupId, label: groupLabels[groupId] ?? groupId, demos: [] };
    result.push(group);
  }
  group.demos.push(demoId);
  return result;
}, []);

const orderedGroups = ['base', 'shadcn', 'other']
  .map((groupId) => groups.find((group) => group.id === groupId))
  .filter((group): group is DemoGroup => !!group);

function getPreviewerClass(demoId: string) {
  return ['demo-matrix__previewer', demoId.includes('transition') && 'transition-demo-container']
    .filter(Boolean)
    .join(' ');
}
---

<TransitionDemoStyles />

<section class="demo-matrix" aria-label="Demo matrix">
  <div class="demo-matrix__summary" aria-label="Demo matrix summary">
    <div>
      <span class="demo-matrix__metric">{demos.length}</span>
      <span class="demo-matrix__label">Demos</span>
    </div>
    <div>
      <span class="demo-matrix__metric">{runtimes.length}</span>
      <span class="demo-matrix__label">Adapters</span>
    </div>
    <div>
      <span class="demo-matrix__metric">{demos.length * runtimes.length}</span>
      <span class="demo-matrix__label">Preview mounts</span>
    </div>
  </div>

  {
    orderedGroups.map((group) => (
      <section class="demo-matrix__group" aria-labelledby={`demo-matrix-${group.id}`}>
        <div class="demo-matrix__group-header">
          <h2 id={`demo-matrix-${group.id}`}>{group.label}</h2>
          <span>{group.demos.length} demos</span>
        </div>

        <div class="demo-matrix__list">
          {group.demos.map((demoId) => (
            <article class="demo-matrix__item" id={demoId}>
              <div class="demo-matrix__item-header">
                <h3>{formatDemoLabel(demoId)}</h3>
                <a href={`#${demoId}`}>{demoId}</a>
              </div>

              <div class="demo-matrix__adapters">
                {runtimes.map((runtime) => (
                  <section
                    class="demo-matrix__adapter"
                    aria-label={`${demoId} ${runtimeLabels[runtime]}`}
                  >
                    <div class="demo-matrix__adapter-label">{runtimeLabels[runtime]}</div>
                    <PrototypePreviewer
                      demoId={demoId}
                      initialRuntime={runtime}
                      runtimes={[runtime]}
                      toolbar={false}
                      codePanel={false}
                      class={getPreviewerClass(demoId)}
                    />
                  </section>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>
    ))
  }
</section>

<style>
  .demo-matrix {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .demo-matrix__summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    padding: 1rem 0;
    border-block: 1px solid var(--color-border);
  }

  .demo-matrix__summary > div {
    min-width: 0;
  }

  .demo-matrix__metric {
    display: block;
    font-size: 1.75rem;
    line-height: 1.1;
    font-weight: 650;
    color: var(--color-foreground);
  }

  .demo-matrix__label {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.8125rem;
    color: var(--color-muted-foreground);
  }

  .demo-matrix__group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .demo-matrix__group-header,
  .demo-matrix__item-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .demo-matrix__group-header {
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .demo-matrix__group-header h2,
  .demo-matrix__item-header h3 {
    margin: 0;
    letter-spacing: 0;
  }

  .demo-matrix__group-header span,
  .demo-matrix__item-header a {
    font-size: 0.8125rem;
    color: var(--color-muted-foreground);
  }

  .demo-matrix__list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .demo-matrix__item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.25rem;
  }

  .demo-matrix__adapters {
    display: grid;
    grid-template-columns: repeat(3, minmax(15rem, 1fr));
    gap: 0.75rem;
  }

  .demo-matrix__adapter {
    min-width: 0;
  }

  .demo-matrix__adapter-label {
    margin-bottom: 0.375rem;
    font-size: 0.75rem;
    font-weight: 650;
    color: var(--color-muted-foreground);
  }

  :global(.demo-matrix__previewer .proto-previewer__preview) {
    min-height: 11rem;
    padding: 1rem;
  }

  :global(.demo-matrix__previewer .proto-previewer__preview .host) {
    min-height: 7rem;
  }

  @media (max-width: 960px) {
    .demo-matrix__adapters {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .demo-matrix__summary {
      grid-template-columns: 1fr;
    }

    .demo-matrix__group-header,
    .demo-matrix__item-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
