---
import { codeToHtml } from 'shiki';
import type { RuntimeId } from './runtimes/registry';
import AdapterSelect from '../override/AdapterSelect.astro';
import { AdapterIds } from './runtimes/registry';
import CodePanel from './CodePanel.astro';
import type { CodeLang } from './CodePanel.astro';

function codeLangForRuntime(runtime: RuntimeId): CodeLang {
  if (runtime === 'vue') return 'vue';
  if (runtime === 'react') return 'tsx';
  return 'html';
}

async function highlightWithShiki(raw: string, langId: CodeLang): Promise<string> {
  let html = await codeToHtml(raw, {
    lang: langId,
    themes: {
      light: 'github-light',
      dark: 'github-dark',
    },
  });
  const safeRaw = raw.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
  html = html.replace(
    /<pre class="([^"]*)"/,
    '<pre class="proto-previewer__code m-0 text-[0.8125rem] leading-6 whitespace-pre $1"'
  );
  html = html.replace(/<code([^>]*)>/, `<code$1 data-raw-code="${safeRaw}">`);
  return html;
}

interface Props {
  prototypeId?: string; // 原型 ID（与 demoId 二选一）
  demoId?: string; // demo ID（*.demo.ts）
  initialRuntime?: RuntimeId; // 默认 'wc'
  props?: Record<string, unknown>; // 传给原型适配后组件的 props
  class?: string;
  toolbar?: boolean; // 是否渲染运行时切换 UI，默认 true
  runtimes?: RuntimeId[]; // 可选的运行时列表，默认 ['wc','react','vue']
  loader?: string; // 动态导入路径，例如 './demo-inline'
  /** 可选：展示的代码片段，提供后显示 Preview | Code 标签页 */
  code?: string;
  hasCode?: boolean;
  codePanel?: boolean;
}

function assertJsonLike(value: unknown, path: string[] = []) {
  const makePath = () => (path.length === 0 ? '(root)' : path.join('.'));
  const fail = (detail: string) => {
    throw new Error(
      `[PrototypePreviewer] props 必须是 JSON-like 数据。\n` +
        `非法值位置: ${makePath()}\n` +
        `问题: ${detail}`
    );
  };

  if (value === null) return;
  const t = typeof value;
  if (t === 'string' || t === 'number' || t === 'boolean') return;
  if (t === 'undefined' || t === 'function' || t === 'symbol' || t === 'bigint') {
    fail(`不支持的类型 "${t}"`);
  }
  if (Array.isArray(value)) {
    for (let i = 0; i < value.length; i++) {
      assertJsonLike(value[i], [...path, `[${i}]`]);
    }
    return;
  }
  if (t === 'object') {
    if (Object.getPrototypeOf(value) !== Object.prototype) {
      fail('仅支持普通对象');
    }
    for (const [k, v] of Object.entries(value as Record<string, unknown>)) {
      assertJsonLike(v, [...path, k]);
    }
    return;
  }

  fail(`不支持的类型 "${t}"`);
}

// 自动扫描 demo_components 下的所有 codeMap 文件
const codeMapModules = import.meta.glob('../../content/docs/demo_components/**/*Code.ts', {
  eager: true,
});

function findCodeMapForDemo(targetDemoId: string): Partial<Record<RuntimeId, string>> | undefined {
  for (const mod of Object.values(codeMapModules)) {
    const map = (mod as { codeMap?: Record<RuntimeId, Record<string, string>> }).codeMap;
    if (!map) continue;
    const hasDemo = Object.values(map).some((runtimeMap) => targetDemoId in runtimeMap);
    if (!hasDemo) continue;
    const result: Partial<Record<RuntimeId, string>> = {};
    for (const [runtime, runtimeMap] of Object.entries(map)) {
      if (runtimeMap[targetDemoId]) {
        result[runtime as RuntimeId] = runtimeMap[targetDemoId];
      }
    }
    return result;
  }
  return undefined;
}

const {
  prototypeId,
  demoId,
  initialRuntime = 'wc',
  props: protoProps = {},
  class: className = '',
  toolbar = true,
  runtimes = AdapterIds,
  loader,
  code: codeSnippet,
  hasCode = false,
  codePanel = true,
} = Astro.props;

const autoCodeMap = demoId ? findCodeMapForDemo(demoId) : undefined;
const effectiveHasCode = codePanel && (hasCode || !!autoCodeMap || !!codeSnippet);
const effectiveCode = autoCodeMap ? autoCodeMap[initialRuntime] : codeSnippet;

const highlights: Record<string, string> = {};
if (autoCodeMap) {
  for (const [runtime, raw] of Object.entries(autoCodeMap)) {
    highlights[runtime] = await highlightWithShiki(raw, codeLangForRuntime(runtime as RuntimeId));
  }
}

if (!prototypeId && !demoId) {
  throw new Error('[PrototypePreviewer] "prototypeId" or "demoId" is required.');
}

if (prototypeId && demoId) {
  throw new Error('[PrototypePreviewer] "prototypeId" and "demoId" cannot be used together.');
}

assertJsonLike(protoProps);

const rid = `pp-${Math.random().toString(36).slice(2)}`;
---

<div
  class:list={['proto-previewer', className]}
  data-previewer-id={rid}
  data-prototype-id={prototypeId || ''}
  data-demo-id={demoId || ''}
  data-initial-runtime={initialRuntime}
  data-props={JSON.stringify(protoProps)}
  data-runtimes={JSON.stringify(runtimes)}
  data-loader={loader || ''}
  data-code-map={autoCodeMap ? JSON.stringify(autoCodeMap) : ''}
  data-code-highlights={Object.keys(highlights).length ? JSON.stringify(highlights) : ''}
>
  {
    toolbar && (
      <div class="proto-previewer__header">
        <div class="proto-previewer__toolbar">
          <label class="proto-previewer__label">Runtime</label>
          <AdapterSelect />
        </div>
      </div>
    )
  }

  <div
    id={`${rid}-preview`}
    role="tabpanel"
    aria-labelledby={hasCode ? `${rid}-preview-tab` : undefined}
    class="proto-previewer__preview-panel"
    data-panel="preview"
  >
    <div class="proto-previewer__preview" role="region" aria-live="polite">
      <div class="host"></div>
    </div>
  </div>

  {effectiveHasCode && <CodePanel code={effectiveCode} lang={codeLangForRuntime(initialRuntime)} />}

  <style>
    .proto-previewer {
      --proto-previewer-radius: 0.75rem;
      --proto-previewer-border: 1px solid var(--color-border);
      --proto-previewer-bg: color-mix(in oklch, var(--color-muted) 30%, transparent);
      --proto-code-fg: var(--color-code-foreground);
      border: var(--proto-previewer-border);
      border-radius: var(--proto-previewer-radius);
      overflow: hidden;
    }

    .proto-previewer__header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.5rem 1rem;
      border-bottom: var(--proto-previewer-border);
      background: color-mix(in oklch, var(--color-muted) 12%, transparent);
    }

    .proto-previewer__toolbar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .proto-previewer__label {
      font-size: 0.8125rem;
      color: var(--color-muted-foreground);
    }

    .proto-previewer__toolbar select {
      padding: 0.375rem 0.625rem;
      font-size: 0.8125rem;
      border: 1px solid var(--color-border);
      border-radius: 0.375rem;
      background: var(--color-background);
      color: var(--color-foreground);
    }

    .proto-previewer__preview-panel {
      display: block;
    }

    .proto-previewer__preview {
      padding: 1.5rem;
      min-height: 16rem;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      background: var(--proto-previewer-bg);
    }

    .proto-previewer__preview .host {
      min-height: 9rem;
      width: 100%;
      display: flex;
      align-items: flex-start;
      justify-content: center;
    }

    @media (max-width: 640px) {
      .proto-previewer__preview {
        padding: 1.1rem;
        min-height: 14rem;
      }

      .proto-previewer__preview .host {
        min-height: 8rem;
      }
    }
  </style>

  <script>
    import { initPreviewer } from './previewer-client';
    import type { RuntimeId } from './runtimes/registry';
    import { AdapterIds } from './runtimes/registry';
    function init() {
      document
        .querySelectorAll<HTMLElement>('.proto-previewer[data-previewer-id]:not([data-inited])')
        .forEach((root) => {
          const prototypeId = root.dataset.prototypeId || '';
          const demoId = root.dataset.demoId || '';
          const initialRuntime = (root.dataset.initialRuntime || 'wc') as RuntimeId;
          const demoProps = root.dataset.props ? JSON.parse(root.dataset.props) : {};
          const runtimeList = root.dataset.runtimes
            ? JSON.parse(root.dataset.runtimes)
            : AdapterIds;
          const loader = root.dataset.loader || '';

          if (!prototypeId && !demoId) {
            console.error('[PrototypePreviewer] missing prototypeId or demoId', root);
            return;
          }
          initPreviewer({
            root,
            prototypeId,
            demoId,
            initialRuntime,
            demoProps,
            runtimeList,
            loader,
          });
        });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</div>
