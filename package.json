{
  "name": "proto-ui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "pnpm": ">=10.32.1 <11"
  },
  "devDependencies": {
    "@proto.ui/types": "workspace:*",
    "@types/node": "^25.6.2",
    "happy-dom": "^15.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "npm": "^11.14.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "docs:dev": "corepack pnpm@10.32.1 --filter apps-www dev",
    "docs:build": "corepack pnpm@10.32.1 --filter apps-www build",
    "docs:preview": "corepack pnpm@10.32.1 --filter apps-www preview",
    "sync:links": "node scripts/sync-shared-links.mjs",
    "release:scan": "node scripts/release/scan.mjs",
    "release:scan:launch": "node scripts/release/scan.mjs --profile launch --check-governance",
    "release:sync-metadata": "node scripts/release/sync-metadata.mjs",
    "release:stage": "node scripts/release/publish.mjs --dry-run",
    "release:stage:launch": "node scripts/release/publish.mjs --dry-run --profile launch --check-governance",
    "release:publish": "node scripts/release/publish.mjs --publish",
    "release:publish:launch": "node scripts/release/publish.mjs --publish --profile launch --check-governance",
    "issues:good-first:dry-run": "node scripts/issues/publish-good-first-issues.mjs --dry-run",
    "issues:good-first:publish": "node scripts/issues/publish-good-first-issues.mjs --publish",
    "check:types:workspace": "tsc -p tsconfig.workspace.json --noEmit",
    "check:types:docs": "corepack pnpm@10.32.1 --filter apps-www check",
    "check:types": "corepack pnpm@10.32.1 -s check:types:workspace && corepack pnpm@10.32.1 -s check:types:docs",
    "format": "prettier --write .",
    "prepare": "husky install",
    "test": "corepack pnpm@10.32.1 -s test:types && corepack pnpm@10.32.1 -s test:runtime",
    "test:types": "echo \"[types] checking type contracts...\" && tsc -p internal/contracts/types/tsconfig.json && echo \"[types] OK\"",
    "test:runtime": "vitest run"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,json,css,md,mdx,astro,yaml,yml}": "prettier --write"
  }
}
